generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  OWNER
  MEMBER
}

enum GroupStatus {
  DRAFT
  PENDING_MEMBERS
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum MembershipStatus {
  INVITED
  ACTIVE
  REMOVED
  LEFT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum CycleStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

enum ContributionStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  OVERDUE
}

enum PaymentMethod {
  BANK_TRANSFER
  OPAY
  PALMPAY
  MONIEPOINT
  CASH
}

enum PenaltyType {
  FIXED
  PERCENTAGE
}

enum PenaltyStatus {
  PENDING
  PAID
  WAIVED
}

enum ProposalType {
  REMOVE_MEMBER
  REPLACE_MEMBER
  CHANGE_PAYOUT_ORDER
  CHANGE_CONTRIBUTION_AMOUNT
  CHANGE_PENALTY_RULES
  PAUSE_GROUP
  DISSOLVE_GROUP
  RESTRUCTURE_CYCLES
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum VoteChoice {
  APPROVE
  REJECT
}

enum NotificationType {
  CONTRIBUTION_DUE
  CONTRIBUTION_APPROVED
  CONTRIBUTION_REJECTED
  CONTRIBUTION_SUBMITTED
  PENALTY_APPLIED
  PROPOSAL_CREATED
  PROPOSAL_APPROVED
  PROPOSAL_REJECTED
  PROPOSAL_EXPIRED
  MEMBER_JOINED
  MEMBER_REMOVED
  GROUP_PAUSED
  GROUP_DISSOLVED
  PAYOUT_UPCOMING
  PAYOUT_RECEIVED
}

// ─────────────────────────────────────────────
// AUTH TABLES (Auth.js v5 compatible)
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  phone         String?
  location      String?
  notificationPrefs Json?
  deletedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  memberships            Membership[]
  contributionsSubmitted Contribution[] @relation("ContributorContributions")
  contributionsReviewed  Contribution[] @relation("ReviewerContributions")
  cyclesAsRecipient      Cycle[]
  votes                  Vote[]
  proposalsCreated       Proposal[]
  notifications          Notification[]
  activityLogs           ActivityLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// GROUPS
// ─────────────────────────────────────────────

model Group {
  id                 String      @id @default(cuid())
  name               String
  description        String?
  contributionAmount Int
  memberCount        Int
  startDate          DateTime
  gracePeriodDays    Int         @default(7)
  penaltyType        PenaltyType @default(FIXED)
  penaltyValue       Int
  status             GroupStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   Membership[]
  invitations   Invitation[]
  cycles        Cycle[]
  proposals     Proposal[]
  notifications Notification[]
  activityLogs  ActivityLog[]

  @@map("groups")
}

// ─────────────────────────────────────────────
// MEMBERSHIPS
// ─────────────────────────────────────────────

model Membership {
  id             String           @id @default(cuid())
  userId         String
  groupId        String
  role           UserRole         @default(MEMBER)
  payoutPosition Int?
  status         MembershipStatus @default(INVITED)

  rulesAcceptedAt     DateTime?
  penaltiesAcceptedAt DateTime?

  joinedAt  DateTime  @default(now())
  removedAt DateTime?

  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  penalties Penalty[]

  @@unique([userId, groupId])
  @@map("memberships")
}

// ─────────────────────────────────────────────
// INVITATIONS
// ─────────────────────────────────────────────

model Invitation {
  id        String           @id @default(cuid())
  groupId   String
  email     String
  token     String           @unique @default(cuid())
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime

  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@map("invitations")
}

// ─────────────────────────────────────────────
// CYCLES
// ─────────────────────────────────────────────

model Cycle {
  id              String      @id @default(cuid())
  groupId         String
  recipientUserId String
  cycleNumber     Int
  startDate       DateTime
  endDate         DateTime
  dueDate         DateTime
  status          CycleStatus @default(UPCOMING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group         Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  recipient     User           @relation(fields: [recipientUserId], references: [id], onDelete: Restrict)
  contributions Contribution[]
  penalties     Penalty[]

  @@unique([groupId, cycleNumber])
  @@map("cycles")
}

// ─────────────────────────────────────────────
// CONTRIBUTIONS
// ─────────────────────────────────────────────

model Contribution {
  id            String             @id @default(cuid())
  cycleId       String
  contributorId String
  amount        Int
  status        ContributionStatus @default(PENDING)
  paymentMethod PaymentMethod?
  rejectionNote String?

  submittedAt  DateTime?
  reviewedAt   DateTime?
  reviewedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cycle       Cycle                  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  contributor User                   @relation("ContributorContributions", fields: [contributorId], references: [id], onDelete: Restrict)
  reviewedBy  User?                  @relation("ReviewerContributions", fields: [reviewedById], references: [id], onDelete: SetNull)
  evidence    ContributionEvidence[]

  @@unique([cycleId, contributorId])
  @@map("contributions")
}

// ─────────────────────────────────────────────
// CONTRIBUTION EVIDENCE
// ─────────────────────────────────────────────

model ContributionEvidence {
  id             String @id @default(cuid())
  contributionId String
  fileUrl        String
  fileType       String
  fileSize       Int?

  uploadedAt DateTime @default(now())

  contribution Contribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)

  @@map("contribution_evidence")
}

// ─────────────────────────────────────────────
// PENALTIES
// ─────────────────────────────────────────────

model Penalty {
  id           String        @id @default(cuid())
  membershipId String
  cycleId      String
  amount       Int
  reason       String
  status       PenaltyStatus @default(PENDING)

  appliedAt  DateTime  @default(now())
  resolvedAt DateTime?

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  cycle      Cycle      @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@map("penalties")
}

// ─────────────────────────────────────────────
// PROPOSALS
// ─────────────────────────────────────────────

model Proposal {
  id         String         @id @default(cuid())
  groupId    String
  proposerId String
  type       ProposalType
  metadata   Json
  status     ProposalStatus @default(PENDING)
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group    Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  proposer User   @relation(fields: [proposerId], references: [id], onDelete: Restrict)
  votes    Vote[]

  @@map("proposals")
}

// ─────────────────────────────────────────────
// VOTES
// ─────────────────────────────────────────────

model Vote {
  id         String     @id @default(cuid())
  proposalId String
  voterId    String
  vote       VoteChoice

  votedAt DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  voter    User     @relation(fields: [voterId], references: [id], onDelete: Restrict)

  @@unique([proposalId, voterId])
  @@map("votes")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  groupId   String?
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  actionUrl String?

  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// ACTIVITY LOGS
// ─────────────────────────────────────────────

model ActivityLog {
  id          String  @id @default(cuid())
  groupId     String
  actorId     String
  actionType  String
  description String
  metadata    Json?

  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  actor User  @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([groupId, createdAt])
  @@map("activity_logs")
}
